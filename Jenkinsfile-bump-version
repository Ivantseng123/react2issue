#!/usr/bin/env groovy

currentBuild.description = "${version} -> ${ref}"
def semverPattern = /^(0|[1-9]\d*)\.(0|[1-9]\d*)\.(0|[1-9]\d*)$/

pipeline {
  agent {
    kubernetes {
      cloud 'SLKE'
      defaultContainer 'golang'
      yaml """
kind: Pod
spec:
  securityContext:
    runAsUser: 0
  containers:
  - name: golang
    image: golang:1.25-alpine
    imagePullPolicy: Always
    command: ['cat']
    tty: true
    resources:
      limits:
        memory: "2Gi"
        cpu: "1"
  - name: git
    image: ${GIT_IMAGE}
    imagePullPolicy: Always
    command: ['cat']
    tty: true
    resources:
      limits:
        memory: "100Mi"
        cpu: "100m"
"""
    }
  }

  environment {
    CREDENTIAL = credentials("${CREDENTIAL_ID}")
  }

  stages {
    stage('Setup') {
      steps {
        container('git') {
          script {
            env.GIT_PATH = sh(
              script: 'echo $GIT_URL | awk -F"github.com/" "{print \\$2}"',
              returnStdout: true
            ).trim()
            sh """
            git remote set-url origin https://$CREDENTIAL_USR:"\$CREDENTIAL_PSW"@github.com/$GIT_PATH".git"
            git config --global user.email "jenkins-bot@example.com"
            git config --global user.name "jenkins[bot]"
            echo \$CREDENTIAL_PSW | gh auth login --with-token
            """
          }
        }
        sh 'go version'
        echo "${params}"
      }
    }

    stage('Check Tag') {
      steps {
        script {
          if (!("${version}" ==~ semverPattern)) {
            error "Tag must be semver but got: ${version}"
          }
        }
        sh """
        sed -i 's/\\(newTag: \\).*/\\1"${version}"/' ./deploy/overlays/example/kustomization.yaml.example
        """
        container('git') {
          sh '[ -z "$(git status -s)" ] && echo "版本號沒異動!" && exit 1 || echo "Good to go!"'
        }
      }
    }

    stage('Unit Testing') {
      steps {
        sh "go test ./..."
      }
    }

    stage('Bump New Version') {
      steps {
        container('git') {
          script {
            env.PR_BRANCH = "bot/bump-version-to-${version}"
          }
          sh """
          git checkout -b ${PR_BRANCH}
          git commit -am "chore: bump version to ${version}"
          git push --set-upstream origin ${PR_BRANCH}
          gh pr create --base ${ref} --title "chore: bump version to ${version}" --body "Bump version to ${version} -> ${ref}"
          gh pr merge ${PR_BRANCH} --merge --admin --delete-branch
          """
        }
      }
    }
  }
}
